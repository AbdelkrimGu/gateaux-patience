# =============================================================================
# Gateaux Patience — environment template
# Copy this file to .env.local and fill in real values.
# Same values go into Netlify → Site settings → Environment variables.
# =============================================================================

# MongoDB Atlas — full SRV connection string, database name in the path
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/gateaux-patience?retryWrites=true&w=majority
MONGODB_DB=gateaux-patience

# AWS S3 (eu-west-3 Paris recommended)
# Variables are prefixed S3_ instead of AWS_ because Netlify reserves AWS_*
# variable names for its own internal use.
S3_REGION=eu-west-3
S3_BUCKET=gateaux-patience-media
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_MAX_UPLOAD_BYTES=104857600

# Google Gemini AI (free tier — https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Admin
ADMIN_PASSWORD=

# Public site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
